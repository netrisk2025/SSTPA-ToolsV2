{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSTPA Tools Startup",
  "version": "0.1.0",
  "identifier": "app.sstpa.startup",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SSTPA Tools — Startup",
        "width": 480,
        "height": 640,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Nicholas Triska",
    "copyright": "2025 Nicholas Triska. All rights reserved.",
    "shortDescription": "SSTPA Tools Startup Software",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
