{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SSTPA Tools",
  "version": "0.1.0",
  "identifier": "app.sstpa.tools",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "SSTPA Tools",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Nicholas Triska",
    "copyright": "2025 Nicholas Triska. All rights reserved.",
    "shortDescription": "SSTPA Tools — Model-Based System Security Engineering",
    "longDescription": "Systems Security-Theoretic Process Analysis (SSTPA) Tools: graph-based system security engineering for large hierarchical systems.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
